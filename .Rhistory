exec [label = '02. EJECUCIÓN (CORE)\\l----------------------------------\\l📊 <b>CÁLCULO DE MEDIANAS</b>\\l🌍 <b>VISUALIZACIÓN GEEMAP</b>\\l📋 <b>TABLAS DE COBERTURA</b>\\l']
# FASE 3: RESULTADOS (Verde)
node [fillcolor = '#E8F5E9', fontcolor = '#1B5E20', color = '#1B5E20']
res  [label = '03. VISUALIZACIÓN\\l----------------------------------\\l🖼️ <b>RENDER LANDSAT/SENTINEL</b>\\l📉 <b>COMPARACIÓN TEMPORAL</b>\\l🌳 <b>DETECCIÓN DE CAMBIOS</b>\\l']
# Flechas más gruesas para que aguanten el diseño
edge [color = '#455A64', penwidth = 3, arrowhead = vee, arrowsize = 1.5]
# Conexiones
conf -> exec
exec -> res
}
")
