library(sf)
library(dplyr)
cat("\n")
cat("╔════════════════════════════════════════════════════════════════╗\n")
cat("║  ACTUALIZACIÓN LORETO 2025                                     ║\n")
cat("╚════════════════════════════════════════════════════════════════╝\n\n")
# AJUSTA ESTA RUTA según donde tengas tu shapefile 2025
ruta_shp_2025 <- "C:/Users/Favio Campos Rivera/Desktop/ACR_dashboard/Vectores_shp_Loreto/2025/MonitoreoDeforestacionAcumulado2025.shp"
# Carpeta donde están tus datos actuales
carpeta_data <- "data"
cat("📂 PASO 1: Leyendo shapefile 2025...\n")
cat("════════════════════════════════════════\n\n")
if (!file.exists(ruta_shp_2025)) {
cat("❌ ERROR: No se encontró el archivo:\n")
cat("   ", ruta_shp_2025, "\n\n")
cat("💡 Verifica la ruta y vuelve a intentar\n\n")
stop("Archivo no encontrado")
}
sf_use_s2(FALSE)
shp_2025 <- st_read(ruta_shp_2025, quiet = FALSE)
cat(sprintf("\n✅ Leído: %d polígonos\n", nrow(shp_2025)))
cat("\n📊 Columnas encontradas:\n")
for (col in names(shp_2025)) {
if (col != "geometry") {
cat(sprintf("   • %s\n", col))
}
}
cat("\n🔧 PASO 2: Corrigiendo nombre de columna...\n")
cat("════════════════════════════════════════\n")
if ("zi_codi" %in% names(shp_2025)) {
cat("✅ Renombrando 'zi_codi' → 'md_causa'\n")
names(shp_2025)[names(shp_2025) == "zi_codi"] <- "md_causa"
} else if ("md_causa" %in% names(shp_2025)) {
cat("✅ Columna 'md_causa' ya existe\n")
} else {
cat("⚠️  No se encontró ni 'zi_codi' ni 'md_causa'\n")
cat("   Se creará columna 'md_causa' vacía\n")
shp_2025$md_causa <- NA
}
cat("\n🔧 PASO 3: Reparando geometrías...\n")
cat("════════════════════════════════════════\n")
shp_2025 <- st_make_valid(shp_2025)
if (is.na(st_crs(shp_2025))) {
cat("⚠️  Sin CRS, asumiendo WGS84\n")
st_crs(shp_2025) <- 4326
} else if (st_crs(shp_2025)$epsg != 4326) {
cat("🔄 Transformando a WGS84...\n")
shp_2025 <- st_transform(shp_2025, 4326)
}
cat("⚡ Simplificando geometrías...\n")
shp_2025 <- st_simplify(shp_2025, dTolerance = 0.0001, preserveTopology = TRUE)
cat("✅ Geometrías procesadas\n")
cat("\n📊 PASO 4: Identificando ACRs...\n")
cat("════════════════════════════════════════\n")
# Ver qué ACRs hay en anp_codi
cat("\nACRs encontrados en anp_codi:\n")
acrs_unicos <- unique(shp_2025$anp_codi)
for (acr in acrs_unicos) {
n <- sum(shp_2025$anp_codi == acr, na.rm = TRUE)
cat(sprintf("   • %s: %d polígonos\n", acr, n))
}
# Mapeo de códigos a nombres de archivo
mapeo_acr <- list(
"ACR09" = "ACR_AA",       # Ampiyacu Apayacu
"ACR10" = "ACR_ANPCH",    # Alto Nanay - Pintuyacu - Chambira
"ACR04" = "ACR_CTT",      # Comunal Tamshiyacu Tahuayo
"ACR17" = "ACR_MK"        # Maijuna Kichwa
)
cat("\n💡 Usando mapeo de códigos:\n")
for (codigo_orig in names(mapeo_acr)) {
cat(sprintf("   %s → %s\n", codigo_orig, mapeo_acr[[codigo_orig]]))
}
cat("\n🔀 PASO 5: Uniendo con datos existentes...\n")
cat("════════════════════════════════════════\n\n")
for (codigo_orig in names(mapeo_acr)) {
codigo_nuevo <- mapeo_acr[[codigo_orig]]
archivo_actual <- file.path(carpeta_data, paste0("deforestacion_", codigo_nuevo, ".rds"))
cat(sprintf("📂 Procesando %s (%s)...\n", codigo_nuevo, codigo_orig))
cat("   ────────────────────────────────────\n")
# Filtrar datos 2025 de este ACR
datos_2025_acr <- shp_2025 %>% filter(anp_codi == codigo_orig)
if (nrow(datos_2025_acr) == 0) {
cat(sprintf("   ⚠️  No hay datos 2025 para %s\n\n", codigo_orig))
next
}
cat(sprintf("   ✅ Datos 2025: %d polígonos\n", nrow(datos_2025_acr)))
# Leer datos existentes
if (file.exists(archivo_actual)) {
datos_existentes <- readRDS(archivo_actual)
cat(sprintf("   ✅ Datos existentes: %d polígonos\n", nrow(datos_existentes)))
# Verificar si ya hay datos 2025
if ("md_anno" %in% names(datos_existentes)) {
datos_2025_existentes <- datos_existentes %>% filter(md_anno == "2025" | md_anno == 2025)
if (nrow(datos_2025_existentes) > 0) {
cat(sprintf("   ⚠️  Ya hay %d polígonos de 2025. Serán reemplazados.\n", nrow(datos_2025_existentes)))
# Eliminar datos 2025 antiguos
datos_existentes <- datos_existentes %>% filter(md_anno != "2025" & md_anno != 2025)
}
}
# Combinar
cat("   🔀 Combinando datos...\n")
datos_combinados <- rbind(datos_existentes, datos_2025_acr)
} else {
cat("   ⚠️  No existe archivo anterior, creando nuevo\n")
datos_combinados <- datos_2025_acr
}
# Agregar código ACR
datos_combinados$ACR_CODIGO <- codigo_nuevo
# Guardar
cat("   💾 Guardando archivo actualizado...\n")
saveRDS(datos_combinados, archivo_actual)
cat(sprintf("   ✅ %s actualizado: %d polígonos totales\n",
basename(archivo_actual), nrow(datos_combinados)))
cat("\n")
}
sf_use_s2(TRUE)
cat("\n")
cat("╔════════════════════════════════════════════════════════════════╗\n")
cat("║  ACTUALIZACIÓN COMPLETADA                                      ║\n")
cat("╚════════════════════════════════════════════════════════════════╝\n\n")
cat("✅ Datos 2025 de Loreto integrados exitosamente\n\n")
cat("📊 RESUMEN POR ACR:\n")
cat("────────────────────────────────────────\n")
for (codigo_nuevo in unique(unlist(mapeo_acr))) {
archivo <- file.path(carpeta_data, paste0("deforestacion_", codigo_nuevo, ".rds"))
if (file.exists(archivo)) {
datos <- readRDS(archivo)
n_total <- nrow(datos)
n_2025 <- sum(datos$md_anno == "2025" | datos$md_anno == 2025, na.rm = TRUE)
cat(sprintf("✅ %s:\n", codigo_nuevo))
cat(sprintf("   Total: %d polígonos\n", n_total))
cat(sprintf("   2025: %d polígonos\n", n_2025))
cat("\n")
}
}
cat("📌 PRÓXIMOS PASOS:\n")
cat("────────────────────────────────────────\n")
cat("1. Reinicia RStudio\n")
cat("2. Ejecuta: shiny::runApp()\n")
cat("3. Los datos 2025 deberían aparecer en el dashboard\n\n")
cat("✅ Todo listo!\n\n")
